{
  "expo": {
    "name": "PermutApp",
    "slug": "ProyectoTrueque",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/permutapp-app-icon.png",
    "scheme": "proyectotrueque",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/permutapp-app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cl.permutapp.app"
    },
    "android": {
      "package": "cl.permutapp.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/permutapp-app-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/permutapp-app-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#047857",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
